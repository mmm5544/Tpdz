-- Hàm tự động nhận diện Request tương thích với Delta X
local function makeRequest(options)
    local req = request or http_request or (http and http.request) or (fluxus and fluxus.request)
    if req then
        return req(options)
    end
    return nil
end

-- Hàm gửi thông báo Webhook Discord
local function sendWebhook(fruitName)
    pcall(function()
        local data = {
            ["content"] = "@everyone ĐÃ TÌM THẤY TRÁI XỊN!",
            ["embeds"] = {{
                ["title"] = "🍒 Phát Hiện Trái Ác Quỷ Mới!",
                ["description"] = "Tìm thấy trái: **" .. fruitName .. "**\nĐã tự động tắt Auto Server Hop để bạn vào nhặt.",
                ["color"] = 65280
            }}
        }
        makeRequest({
            Url = WEBHOOK_URL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(data)
        })
    end)
end

-- Hàm thực hiện chuyển Server (Tối ưu chống kẹt)
local function serverHop()
    hopBtn.Text = "Đang tìm server mới..."
    
    -- Cách 1: Sử dụng API lấy danh sách server công khai (Yêu cầu executor hỗ trợ Request)
    local success, err = pcall(function()
        local req = makeRequest({Url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Desc&limit=50"})
        if req and req.Body then
            local body = HttpService:JSONDecode(req.Body)
            if body and body.data then
                local servers = {}
                for _, v in pairs(body.data) do
                    if v.playing and v.maxPlayers and v.playing < v.maxPlayers and v.id ~= game.JobId then
                        table.insert(servers, v.id)
                    end
                end
                if #servers > 0 then
                    TeleportService:TeleportToPlaceInstance(game.PlaceId, servers[math.random(1, #servers)], player)
                    return true
                end
            end
        end
        return false
    end)
    
    -- Cách 2: Phương pháp dự phòng nếu Executor lỗi Request (Tự nhảy server ngẫu nhiên mặc định)
    if not success then
        hopBtn.Text = "Dự phòng: Nhảy SV ngẫu nhiên..."
        pcall(function()
            TeleportService:Teleport(game.PlaceId, player)
        end)
    end
end

-- Quét tìm trái trong Workspace
local function scanWorkspace(parent, list)
    for _, obj in ipairs(parent:GetChildren()) do
        if string.find(obj.Name, "Fruit") and not isExcluded(obj.Name) then
            table.insert(list, obj)
        end
        scanWorkspace(obj, list)
    end
end

-- Hàm cập nhật logic chính
local isHopping = false
local function checkAndManageFruits()
    if isHopping then return end
    
    local fruits = {}
    scanWorkspace(workspace, fruits)
    
    scroll:ClearAllChildren()
    UIListLayout.Parent = scroll
    
    if #fruits > 0 then
        -- Tìm thấy trái xịn: DỪNG HOP SERVER NGAY
        if autoServerHop then
            autoServerHop = false
            hopBtn.Text = "Auto Server Hop: OFF"
            hopBtn.BackgroundColor3 = Color3.fromRGB(50, 120, 50)
            sendWebhook(fruits[1].Name)
        end
        
        -- Hiển thị trái lên danh sách GUI
        for _, obj in ipairs(fruits) do
            createESP(obj)
            
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, -10, 0, 30)
            btn.BackgroundColor3 = Color3.fromRGB(65, 65, 65)
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            btn.Text = obj.Name
            btn.Parent = scroll
            
            btn.MouseButton1Click:Connect(function()
                selectedFruit = obj
                tpCornerBtn.Visible = true
                tpCornerBtn.Text = "TP: " .. obj.Name
            end)
        end
    else
        -- Không có trái xịn hoặc trống trơn
        local noFruit = Instance.new("TextLabel")
        noFruit.Size = UDim2.new(1, -10, 0, 30)
        noFruit.BackgroundTransparency = 1
        noFruit.TextColor3 = Color3.fromRGB(255, 100, 100)
        noFruit.Text = "Không có trái ác quỷ hợp lệ"
        noFruit.Parent = scroll
        
        -- Chờ game ổn định 1.5 giây rồi nhảy server để tránh bị Roblox chặn dịch chuyển liền
        if autoServerHop and not isHopping then
            isHopping = true
            task.wait(1.5)
            serverHop()
        end
    end
end

-- Vòng lặp quét liên tục
task.spawn(function()
