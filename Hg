-- ==========================================
-- [4] NÚT MIX JUICINGBOWL (1 LẦN CLICK)
-- ==========================================
local function findMixerClickDetector()
    local kitchen = workspace:FindFirstChild("Island8") and workspace.Island8:FindFirstChild("Kitchen")
    if not kitchen then return nil end
    local function recursiveSearch(parent)
        for _, obj in ipairs(parent:GetChildren()) do
            if obj.Name == "Mixer1" then
                local cd = obj:FindFirstChildOfClass("ClickDetector")
                if cd then return cd end
            end
            local result = recursiveSearch(obj)
            if result then return result end
        end
        return nil
    end
    return recursiveSearch(kitchen)
end

