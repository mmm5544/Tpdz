-- Vòng lặp tự động sửa lỗi mất Nhân vật khi hồi sinh (Reset)
task.spawn(function()
    local maxDistance = 32 -- Bạn có thể tăng/giảm khoảng cách kích hoạt tại đây

    while task.wait(0.5) do
        if autoClicking then
            local char = player.Character
            local rootPart = char and char:FindFirstChild("HumanoidRootPart")
            
            -- Chỉ chạy nếu nhân vật còn sống và có HRP
            if rootPart then
                for _, obj in ipairs(workspace:GetDescendants()) do
                    if obj:IsA("ClickDetector") then
                        local parent = obj.Parent
                        if parent and (parent:IsA("BasePart") or parent:FindFirstChild("PrimaryPart")) then
                            local partPosition = parent:IsA("BasePart") and parent.Position or parent.PrimaryPart.Position
                            
                            -- Kiểm tra khoảng cách
                            if (partPosition - rootPart.Position).Magnitude <= maxDistance then
                                pcall(function() fireclickdetector(obj) end)
                            end
                        end
                    end
                end
            end
        end
    end
end)

